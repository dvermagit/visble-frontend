{
  "redirects": [
    {
      "source": "/blog/:slug/",
      "destination": "/blog/:slug",
      "permanent": true
    },
    {
      "source": "/category/:category",
      "destination": "/blog/category/:category",
      "permanent": true
    },
    {
      "source": "/feed",
      "destination": "/blog/rss.xml",
      "permanent": true
    }
  ]
}